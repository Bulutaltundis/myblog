{
  "openapi": "3.0.0",
  "info": {
    "title": "Kullanıcı Yönetim API",
    "version": "1.0.0",
    "description": "Sistemdeki kullanıcıları yönetmek için kullanılan temel API."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Yerel Geliştirme Sunucusu"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "summary": "Tüm kullanıcıları listele",
        "responses": {
          "200": {
            "description": "Başarılı bir şekilde liste döndü",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      }
    }
  }
}